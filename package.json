{
  "name": "gentlebob-site",
  "version": "2.0.0",
  "private": true,
  "description": "Gentlebob site.",
  "homepage": "https://www.gentlebob.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gentlebob/gentlebob.github.io.git"
  },
  "license": "MIT",
  "author": "gentlebob",
  "contributors": [
    "Mrewy"
  ],
  "type": "module",
  "main": "index.html",
  "scripts": {
    "build-bingo": "sass bingo/src/styles/bingo.scss bingo/dist/styles/bingo.css --no-source-map && esbuild bingo/src/scripts/bingo.ts --outfile=bingo/dist/scripts/bingo.js --tsconfig=bingo/src/tsconfig.json --format=esm --bundle",
    "cspell": "cspell . --verbose",
    "eslint": "eslint \"**/*.ts\" --flag unstable_native_nodejs_ts_config --concurrency=auto",
    "markdownlint": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "prepare": "node .husky/install.ts",
    "prettier": "prettier . --write",
    "typecheck-bingo": "tsc --build bingo/src --noEmit"
  },
  "dependencies": {
    "sass": "^1.101.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/format": "^21.2.0",
    "@commitlint/types": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@typescript/native": "npm:typescript@^7.1.0-dev.20260708.3",
    "cspell": "^10.0.1",
    "esbuild": "0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "markdownlint-cli2": "^0.23.0",
    "prettier": "^3.9.5",
    "prettier-plugin-sh": "^0.19.0",
    "typescript": "npm:@typescript/typescript6@^6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "engines": {
    "node": "v26.5.0",
    "npm": ">=11.17.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "allowScripts": {
    "fsevents": true,
    "esbuild": true,
    "@parcel/watcher": true
  }
}
